# NIMBUS Environment Variables Configuration

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (PostGIS enabled in 'postgis' schema)
# Format: postgresql://postgres:<password>@<host>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nimbus

# ─── Demo & Fallback ─────────────────────────────────────────────────────────
# Set to true to serve cached/mock data instead of live external APIs
DEMO_MODE=true

# City to ingest data for (must have live OpenAQ coverage)
DEMO_CITY=Bangalore

# Demo bounding box for cache pre-warm: lat1,lon1,lat2,lon2
DEMO_BBOX=12.87,77.47,13.08,77.78

# ─── External API Keys ───────────────────────────────────────────────────────
# OpenAQ v3 API key — register free at https://openaq.org
OPENAQ_API_KEY=your_openaq_api_key_here

# OpenWeatherMap API key — register free at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
